{
  "meta": {
    "name": "Full Production Pipeline",
    "category": "chain",
    "description": "Record Demo -> Probe Duration -> Generate Music -> Assemble -> Export MP4",
    "estimated_minutes": 10,
    "tags": ["production", "recording", "music", "video"]
  },
  "nodes": {
    "1": {
      "class_type": "chain.config.VideoSettings",
      "inputs": {
        "title": "OnyxKraken",
        "demo_name": "chain_demo"
      },
      "position": [60, 120]
    },
    "2": {
      "class_type": "chain.config.MusicSettings",
      "inputs": {
        "genre": "lo-fi",
        "quality": "quick_draft"
      },
      "position": [60, 320]
    },
    "3": {
      "class_type": "chain.record.RecordDemo",
      "inputs": {
        "demo_name": ["1", 1]
      },
      "position": [340, 120]
    },
    "4": {
      "class_type": "chain.probe.ProbeDuration",
      "inputs": {
        "recording_path": ["3", 0]
      },
      "position": [620, 120]
    },
    "5": {
      "class_type": "chain.music.GenerateMusic",
      "inputs": {
        "video_duration": ["4", 0],
        "music_genre": ["2", 0],
        "music_quality": ["2", 1]
      },
      "position": [620, 320]
    },
    "6": {
      "class_type": "chain.edit.AssembleJustEdit",
      "inputs": {
        "recording_path": ["3", 0],
        "music_path": ["5", 0],
        "video_title": ["1", 0]
      },
      "position": [920, 200]
    },
    "7": {
      "class_type": "chain.export.ExportVideo",
      "inputs": {
        "recording_path": ["3", 0],
        "music_path": ["5", 0],
        "video_duration": ["4", 0]
      },
      "position": [1200, 200]
    }
  }
}
