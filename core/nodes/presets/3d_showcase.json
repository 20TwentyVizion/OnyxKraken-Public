{
  "meta": {
    "name": "3D Showcase",
    "category": "chain",
    "description": "Blender Build + Record -> Probe -> Generate Soundtrack -> Assemble -> Export",
    "estimated_minutes": 15,
    "tags": ["3d", "blender", "showcase", "music", "video"]
  },
  "nodes": {
    "1": {
      "class_type": "chain.config.MusicSettings",
      "inputs": {
        "genre": "ambient",
        "quality": "balanced"
      },
      "position": [60, 320]
    },
    "2": {
      "class_type": "chain.blender.BuildAndRecord",
      "inputs": {
        "build_type": "house",
        "demo_name": "blender_showcase"
      },
      "position": [60, 100]
    },
    "3": {
      "class_type": "chain.probe.ProbeDuration",
      "inputs": {
        "recording_path": ["2", 0]
      },
      "position": [400, 100]
    },
    "4": {
      "class_type": "chain.music.GenerateMusic",
      "inputs": {
        "video_duration": ["3", 0],
        "music_genre": ["1", 0],
        "music_quality": ["1", 1]
      },
      "position": [400, 320]
    },
    "5": {
      "class_type": "chain.edit.AssembleJustEdit",
      "inputs": {
        "recording_path": ["2", 0],
        "music_path": ["4", 0],
        "video_title": "OnyxKraken 3D Showcase"
      },
      "position": [740, 200]
    },
    "6": {
      "class_type": "chain.export.ExportVideo",
      "inputs": {
        "recording_path": ["2", 0],
        "music_path": ["4", 0],
        "video_duration": ["3", 0]
      },
      "position": [1060, 200]
    }
  }
}
