{
  "_comment": "AgentFace engine spec — single source of truth for face rendering. Decoupled from any specific project.",
  "reference": {
    "width": 400,
    "height": 360
  },
  "colors": {
    "bg": "#050810",
    "face": "#0c1220",
    "face_border": "#0e2a3d",
    "eye_sclera": "#0a1828",
    "eye_pupil": "#00d4ff",
    "eye_glow_inner": "#005580",
    "eye_glow_outer": "#002838",
    "eye_highlight": "#eefaff",
    "mouth_interior": "#040810",
    "accent_bright": "#00d4ff",
    "accent_mid": "#006688",
    "accent_dim": "#0e2a3d",
    "accent_vdim": "#091520"
  },
  "emotion_accents": {
    "neutral": "#00d4ff",
    "thinking": "#4488ff",
    "curious": "#00eeff",
    "satisfied": "#44ffaa",
    "confused": "#ff8844",
    "determined": "#8888ff",
    "amused": "#ffcc44",
    "surprised": "#ff66aa",
    "listening": "#66ffcc",
    "working": "#44aaff",
    "focused": "#55ccff",
    "happy": "#44ff88",
    "sad": "#6688cc",
    "excited": "#ff88ff",
    "skeptical": "#cc8844",
    "proud": "#88aaff"
  },
  "geometry": {
    "eye_width": 54,
    "eye_height": 62,
    "eye_spacing": 100,
    "eye_y": 130,
    "pupil_radius": 13,
    "pupil_max_ox": 14,
    "pupil_max_oy": 10,
    "mouth_y": 250,
    "mouth_width": 70,
    "mouth_height": 10
  },
  "animation": {
    "blink_interval_min": 2.5,
    "blink_interval_max": 6.0,
    "blink_duration": 0.12,
    "double_blink_chance": 0.25,
    "gaze_change_min": 0.8,
    "gaze_change_max": 3.5,
    "gaze_speed": 5.0,
    "fps": 60
  },
  "phonemes": {
    "types": ["closed", "small", "medium", "wide", "round", "teeth"],
    "char_map": {
      "a": "wide", "e": "medium", "i": "medium",
      "o": "round", "u": "round",
      "b": "closed", "m": "closed", "p": "closed",
      "f": "teeth", "v": "teeth",
      "w": "round", "r": "small",
      "l": "medium", "n": "small", "t": "small",
      "d": "small", "s": "small", "z": "small",
      "k": "small", "g": "small", "h": "medium",
      "y": "medium", "j": "medium",
      " ": "closed", ".": "closed", ",": "closed",
      "!": "closed", "?": "closed"
    },
    "targets": {
      "closed": [0.0, 1.0],
      "small": [0.3, 0.85],
      "medium": [0.55, 1.0],
      "wide": [0.9, 1.2],
      "round": [0.65, 0.5],
      "teeth": [0.25, 1.15]
    },
    "chars_per_sec": 12.0
  },
  "emotion_presets": {
    "neutral":    { "squint": 0.0,   "brow_raise": 0.0,   "eye_widen": 0.0,  "mouth_curve": 0.0,   "pupil_size": 1.0,  "gaze_speed": 1.0,  "blink_rate": 1.0,  "intensity": 0.0  },
    "thinking":   { "squint": 0.35,  "brow_raise": -0.40, "eye_widen": 0.0,  "mouth_curve": -0.15, "pupil_size": 0.80, "gaze_speed": 0.3,  "blink_rate": 0.4,  "intensity": 0.80 },
    "curious":    { "squint": -0.20, "brow_raise": 0.55,  "eye_widen": 0.30, "mouth_curve": 0.10,  "pupil_size": 1.25, "gaze_speed": 1.6,  "blink_rate": 1.2,  "intensity": 0.80 },
    "satisfied":  { "squint": 0.25,  "brow_raise": 0.15,  "eye_widen": 0.0,  "mouth_curve": 0.80,  "pupil_size": 1.05, "gaze_speed": 0.4,  "blink_rate": 0.6,  "intensity": 0.80 },
    "confused":   { "squint": 0.10,  "brow_raise": -0.60, "eye_widen": 0.40, "mouth_curve": -0.50, "pupil_size": 1.15, "gaze_speed": 2.0,  "blink_rate": 1.5,  "intensity": 0.90 },
    "determined": { "squint": 0.40,  "brow_raise": -0.50, "eye_widen": 0.0,  "mouth_curve": -0.10, "pupil_size": 0.78, "gaze_speed": 0.2,  "blink_rate": 0.35, "intensity": 0.90 },
    "amused":     { "squint": 0.22,  "brow_raise": 0.35,  "eye_widen": 0.12, "mouth_curve": 0.90,  "pupil_size": 1.12, "gaze_speed": 0.8,  "blink_rate": 1.0,  "intensity": 0.85 },
    "surprised":  { "squint": -0.40, "brow_raise": 0.75,  "eye_widen": 0.55, "mouth_curve": 0.0,   "pupil_size": 1.40, "gaze_speed": 0.15, "blink_rate": 0.2,  "intensity": 0.95 },
    "listening":  { "squint": -0.08, "brow_raise": 0.35,  "eye_widen": 0.18, "mouth_curve": 0.0,   "pupil_size": 1.18, "gaze_speed": 0.4,  "blink_rate": 0.75, "intensity": 0.60 },
    "working":    { "squint": 0.25,  "brow_raise": -0.22, "eye_widen": 0.0,  "mouth_curve": 0.0,   "pupil_size": 0.88, "gaze_speed": 0.5,  "blink_rate": 0.6,  "intensity": 0.60 },
    "focused":    { "squint": 0.30,  "brow_raise": -0.30, "eye_widen": 0.0,  "mouth_curve": -0.10, "pupil_size": 0.82, "gaze_speed": 0.2,  "blink_rate": 0.35, "intensity": 0.80 },
    "happy":      { "squint": 0.30,  "brow_raise": 0.40,  "eye_widen": 0.12, "mouth_curve": 1.0,   "pupil_size": 1.18, "gaze_speed": 0.7,  "blink_rate": 0.8,  "intensity": 0.95 },
    "sad":        { "squint": 0.10,  "brow_raise": -0.65, "eye_widen": 0.0,  "mouth_curve": -0.80, "pupil_size": 0.80, "gaze_speed": 0.2,  "blink_rate": 0.45, "intensity": 0.85 },
    "excited":    { "squint": -0.25, "brow_raise": 0.65,  "eye_widen": 0.45, "mouth_curve": 0.95,  "pupil_size": 1.38, "gaze_speed": 1.8,  "blink_rate": 1.4,  "intensity": 0.95 },
    "skeptical":  { "squint": 0.20,  "brow_raise": -0.35, "eye_widen": 0.10, "mouth_curve": -0.30, "pupil_size": 1.08, "gaze_speed": 0.5,  "blink_rate": 0.55, "intensity": 0.75 },
    "proud":      { "squint": 0.15,  "brow_raise": 0.28,  "eye_widen": 0.05, "mouth_curve": 0.60,  "pupil_size": 1.08, "gaze_speed": 0.3,  "blink_rate": 0.5,  "intensity": 0.75 },
    "sleep":      { "squint": 0.90,  "brow_raise": -0.20, "eye_widen": -0.5, "mouth_curve": 0.0,   "pupil_size": 0.10, "gaze_speed": 0.0,  "blink_rate": 0.0,  "intensity": 1.0  }
  }
}
